

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regla maestra para tu estructura actual
    // userId: es el ID del usuario (i7n3X441...)
    // {document=**}: permite entrar a dbdata, al historial y a los IDs numéricos
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regla de respaldo por si tienes datos en otras rutas
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

